# ============================================================
#  ReconFlow — Configuración
#  Copia este archivo a config.env y edítalo
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="123456789:ABCDEFabcdef..."
TELEGRAM_CHAT_ID="-100123456789"

# ── Herramientas (deja vacío para usar el PATH por defecto) ──
SUBFINDER_BIN="subfinder"
AMASS_BIN="amass"
BBOT_BIN="bbot"
HTTPX_BIN="httpx"
DNSX_BIN="dnsx"
NUCLEI_BIN="nuclei"
KATANA_BIN="katana"
GAU_BIN="gau"
SUBZY_BIN="subzy"
FFUF_BIN="ffuf"

# ── Nuclei ────────────────────────────────────────────────────
# Severidades a reportar (separadas por coma)
NUCLEI_SEVERITY="medium,high,critical"
# Templates extra (ruta local, opcional)
NUCLEI_EXTRA_TEMPLATES=""

# ── Opciones de scan ─────────────────────────────────────────
# Threads para httpx/dnsx
RESOLVE_THREADS=50
# Threads para nuclei
NUCLEI_THREADS=25
# Profundidad de crawling (katana)
CRAWL_DEPTH=3
# Tiempo máximo de crawling por dominio (segundos)
CRAWL_TIMEOUT=300
# Rate limit ffuf (req/s)
FFUF_RATE=50

# ── Scheduler ────────────────────────────────────────────────
# Intervalo en horas entre scans
SCHEDULE_HOURS=12

# ── Acunetix (opcional) ──────────────────────────────────────
# Instancia local fuera de Docker
# La API key se encuentra en: Acunetix → Profile → API Key
ACUNETIX_URL=https://localhost:3443
ACUNETIX_API_KEY=
ACUNETIX_VERIFY_SSL=false   # true si tienes certificado válido

# ── AI Advisor (opcional) ────────────────────────────────────
# API key de Anthropic para análisis inteligente al final de cada scan
# Obtén una en: https://console.anthropic.com
# Coste estimado: $0.01-0.10 por dominio por scan
ANTHROPIC_API_KEY=""

# ── CMS Scanner ──────────────────────────────────────────────
# WPScan API Token (gratuito para 25 req/día: https://wpscan.com/register)
WPSCAN_API_TOKEN=""

# ── Watchdog (supervisor de procesos) ───────────────────────
WATCHDOG_ENABLED=true
MAX_CPU_PERCENT=90      # % CPU máximo antes de avisar
MAX_MEM_MB=2048         # MB memoria máxima por proceso

# Timeouts por módulo en segundos (opcional — hay defaults razonables)
# TIMEOUT_04_NUCLEI_SCAN=1800
# TIMEOUT_06_ACTIVE_SCAN=1800
# TIMEOUT_13_PORT_SCAN=900

# ── Smart Scan ───────────────────────────────────────────────
# Callback para detección de SSRF/OAST (usa Interactsh o tu propio servidor)
# Deja vacío para usar solo nuclei con sus callbacks internos
SSRF_CALLBACK=""

# ── Vault de credenciales ────────────────────────────────────
# Clave para cifrar/descifrar el vault (AES-256-GCM)
# Genera una segura: openssl rand -base64 32
VAULT_KEY=""

# ── GitHub (para dorking y trufflehog) ───────────────────────
# Token gratuito en: https://github.com/settings/tokens
# Permisos necesarios: public_repo (solo lectura)
GITHUB_TOKEN=""

# ── Dehashed API ─────────────────────────────────────────────
DEHASHED_EMAIL=""
DEHASHED_API_KEY=""

# ── Paths ────────────────────────────────────────────────────
DB_PATH="$(dirname "$0")/data/recon.db"
OUTPUT_BASE="$(dirname "$0")/output"
LOG_LEVEL="INFO"   # DEBUG | INFO | WARN | ERROR

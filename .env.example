# ============================================================
#  Hackeadora — Variables de entorno
#  Copia a .env y edita
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCDEFabcdef...
TELEGRAM_CHAT_ID=-100123456789
# URL pública de tu VPS para recibir webhooks de Telegram
TELEGRAM_WEBHOOK_URL=https://TU_VPS_IP_O_DOMINIO/telegram/webhook

# ── Puertos ──────────────────────────────────────────────────
DASHBOARD_PORT=8080
CAIDO_PORT=8181
CAIDO_UI_PORT=7070

# ── Scan ─────────────────────────────────────────────────────
SCHEDULE_HOURS=12
NUCLEI_SEVERITY=medium,high,critical
NUCLEI_THREADS=25
RESOLVE_THREADS=50
CRAWL_DEPTH=3
CRAWL_TIMEOUT=300

# ── Proxy (Caido interno) ────────────────────────────────────
PROXY_HOST=caido
PROXY_PORT=8181
